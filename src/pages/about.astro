---
import Layout from "../layouts/Layout.astro";

const heroImage =
  "https://images.unsplash.com/photo-1764183122444-4236b2c75dd6?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjA5NjV8&ixlib=rb-4.1.0&q=80&w=1080";
---

<Layout title="About" activePage="About">
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="flex h-[520px] bg-[#1B3A28]">
    <!-- Left: text -->
    <div class="flex flex-1 flex-col justify-center gap-6 px-16 py-20">
      <!-- Badge -->
      <div class="flex w-fit items-center gap-2 rounded-full bg-[#2D5E3A] px-4 py-1.5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#A8CCAF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <span class="text-[12px] font-semibold text-[#A8CCAF]">About SES</span>
      </div>

      <!-- Headline -->
      <h1 class="font-serif text-[44px] font-bold leading-[1.2] text-white">
        We Believe in a World Where People and Planet Thrive Together
      </h1>

      <!-- Description -->
      <p class="text-base leading-[1.7] text-[#7A9A80]">
        SustainEnviro Solutions is an environmental sustainability organization dedicated to protecting ecosystems, empowering communities, and building a greener future for the next generation.
      </p>
    </div>

    <!-- Right: nature photo -->
    <div
      class="flex-1"
      style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}
    ></div>
  </section>

  <!-- ── Mission / Vision / Values ─────────────────────────────────── -->
  <section class="flex flex-col items-center gap-12 bg-[#F5F3EE] px-20 py-20">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">WHO WE ARE</span>
      <h2 class="font-serif text-[40px] font-bold text-[#1B3A28]">Guided by Purpose, Driven by Impact</h2>
    </div>

    <!-- Cards -->
    <div class="flex w-full gap-8">
      <!-- Our Mission -->
      <div class="flex flex-1 flex-col gap-5 rounded-xl border border-[#E8EDE5] bg-white p-8 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-14 w-14 items-center justify-center rounded-[16px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <h3 class="font-serif text-[24px] font-bold text-[#1B3A28]">Our Mission</h3>
        <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
          To advance environmental sustainability through innovative programs that protect ecosystems, empower communities, and create lasting change across Africa and beyond.
        </p>
      </div>

      <!-- Our Vision -->
      <div class="flex flex-1 flex-col gap-5 rounded-xl border border-[#E8EDE5] bg-white p-8 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-14 w-14 items-center justify-center rounded-[16px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h3 class="font-serif text-[24px] font-bold text-[#1B3A28]">Our Vision</h3>
        <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
          A world where every community has access to clean energy, healthy ecosystems, sustainable food systems, and quality education that nurtures environmental stewardship.
        </p>
      </div>

      <!-- Our Values -->
      <div class="flex flex-1 flex-col gap-5 rounded-xl border border-[#E8EDE5] bg-white p-8 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-14 w-14 items-center justify-center rounded-[16px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 3h12l4 6-10 13L2 9Z"/>
            <path d="M11 3 8 9l4 13 4-13-3-6"/>
            <path d="M2 9h20"/>
          </svg>
        </div>
        <h3 class="font-serif text-[24px] font-bold text-[#1B3A28]">Our Values</h3>
        <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
          Integrity, collaboration, and innovation guide everything we do. We believe in transparency, community ownership, and science-driven solutions for a sustainable planet.
        </p>
      </div>
    </div>
  </section>

  <!-- ── SDG Focus ──────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-12 bg-white px-20 py-20">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">OUR SDG FOCUS</span>
      <h2 class="font-serif text-[40px] font-bold text-[#1B3A28]">Aligned With Global Goals</h2>
      <p class="max-w-[520px] text-base text-[#7A9A80]">
        Our programs directly support four United Nations Sustainable Development Goals.
      </p>
    </div>

    <!-- Cards -->
    <div class="flex w-full gap-6">
      <!-- SDG 7 -->
      <div class="flex flex-1 flex-col items-center gap-4 rounded-xl bg-[#F5F3EE] p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div class="flex h-16 w-16 items-center justify-center rounded-[16px] bg-[#FCC30B]">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>
        <span class="font-mono text-[13px] font-bold text-[#FCC30B]">SDG 7</span>
        <h3 class="text-center text-[17px] font-semibold text-[#1B3A28]">Affordable &amp; Clean Energy</h3>
        <p class="text-center text-sm leading-[1.6] text-[#7A9A80]">
          Expanding access to renewable energy sources in underserved communities across the region.
        </p>
      </div>

      <!-- SDG 13 -->
      <div class="flex flex-1 flex-col items-center gap-4 rounded-xl bg-[#F5F3EE] p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div class="flex h-16 w-16 items-center justify-center rounded-[16px] bg-[#3F7E44]">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v2"/>
            <path d="m4.93 4.93 1.41 1.41"/>
            <path d="M20 12h2"/>
            <path d="m19.07 4.93-1.41 1.41"/>
            <path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/>
            <path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6z"/>
          </svg>
        </div>
        <span class="font-mono text-[13px] font-bold text-[#3F7E44]">SDG 13</span>
        <h3 class="text-center text-[17px] font-semibold text-[#1B3A28]">Climate Action</h3>
        <p class="text-center text-sm leading-[1.6] text-[#7A9A80]">
          Driving climate resilience through conservation, reforestation, and emissions reduction programs.
        </p>
      </div>

      <!-- SDG 2 -->
      <div class="flex flex-1 flex-col items-center gap-4 rounded-xl bg-[#F5F3EE] p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div class="flex h-16 w-16 items-center justify-center rounded-[16px] bg-[#DDA63A]">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 22 16 8"/>
            <path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4z"/>
            <path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0z"/>
          </svg>
        </div>
        <span class="font-mono text-[13px] font-bold text-[#DDA63A]">SDG 2</span>
        <h3 class="text-center text-[17px] font-semibold text-[#1B3A28]">Zero Hunger</h3>
        <p class="text-center text-sm leading-[1.6] text-[#7A9A80]">
          Supporting sustainable agriculture and food processing to eliminate hunger in vulnerable populations.
        </p>
      </div>

      <!-- SDG 4 -->
      <div class="flex flex-1 flex-col items-center gap-4 rounded-xl bg-[#F5F3EE] p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div class="flex h-16 w-16 items-center justify-center rounded-[16px] bg-[#C5192D]">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <span class="font-mono text-[13px] font-bold text-[#C5192D]">SDG 4</span>
        <h3 class="text-center text-[17px] font-semibold text-[#1B3A28]">Quality Education</h3>
        <p class="text-center text-sm leading-[1.6] text-[#7A9A80]">
          Building schools and integrating environmental literacy into curricula for lasting generational impact.
        </p>
      </div>
    </div>
  </section>

  <!-- ── Team ───────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-12 bg-[#F5F3EE] px-20 py-20">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">LEADERSHIP</span>
      <h2 class="font-serif text-[40px] font-bold text-[#1B3A28]">Meet the Team Behind the Mission</h2>
      <p class="text-base text-[#7A9A80]">Passionate leaders driving sustainability forward every day.</p>
    </div>

    <!-- Grid -->
    <div class="flex justify-center gap-8">
      <div class="flex w-[280px] flex-col items-center gap-4">
        <img src="/tm1.png" alt="Dr. Amara Osei" class="h-[300px] w-[280px] rounded-xl object-cover" />
        <p class="text-[17px] font-semibold text-[#1B3A28]">Dr. Amara Osei</p>
        <p class="text-sm text-[#4A8C5E]">Executive Director</p>
      </div>

      <div class="flex w-[280px] flex-col items-center gap-4">
        <img src="/tm2.png" alt="James Kariuki" class="h-[300px] w-[280px] rounded-xl object-cover" />
        <p class="text-[17px] font-semibold text-[#1B3A28]">James Kariuki</p>
        <p class="text-sm text-[#4A8C5E]">Head of Programs</p>
      </div>

      <div class="flex w-[280px] flex-col items-center gap-4">
        <img src="/tm3.png" alt="Fatima Al-Hassan" class="h-[300px] w-[280px] rounded-xl object-cover" />
        <p class="text-[17px] font-semibold text-[#1B3A28]">Fatima Al-Hassan</p>
        <p class="text-sm text-[#4A8C5E]">Director of Partnerships</p>
      </div>

      <div class="flex w-[280px] flex-col items-center gap-4">
        <img src="/tm4.png" alt="Samuel Nkomo" class="h-[300px] w-[280px] rounded-xl object-cover" />
        <p class="text-[17px] font-semibold text-[#1B3A28]">Samuel Nkomo</p>
        <p class="text-sm text-[#4A8C5E]">Chief of Research</p>
      </div>
    </div>
  </section>
</Layout>
