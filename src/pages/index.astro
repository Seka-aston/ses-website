---
import Layout from "../layouts/Layout.astro";

const heroImage =
  "https://images.unsplash.com/photo-1632486940292-821417562967?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjI5NDR8&ixlib=rb-4.1.0&q=80&w=1080";
---

<Layout title="Home">
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section
    class="relative flex min-h-[480px] items-center justify-center overflow-hidden px-6 py-20 md:h-[720px] md:px-20 md:py-0"
    style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0 bg-[#1C4539]/70"></div>

    <div class="relative z-10 flex flex-col items-center gap-7 text-center">
      <div class="flex items-center gap-2 rounded-full bg-[#4e6549] px-5 py-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B9F0AE" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
        </svg>
        <span class="text-[13px] font-medium text-[#B9F0AE]">Environmental Sustainability NGO</span>
      </div>

      <h1 class="max-w-[900px] font-serif text-[38px] font-bold leading-tight text-white md:text-[52px] lg:text-[64px]">
        Sustainability, The Way to Go
      </h1>

      <p class="max-w-[700px] text-[15px] leading-[1.6] text-[#B9F0AE] md:text-[18px]">
        Protecting the next generation through impactful programs in renewable energy, environmental conservation, agricultural innovation, and quality education.
      </p>

      <a
        href="/get-involved"
        class="flex items-center gap-2.5 rounded-full bg-[#B9F0AE] px-8 py-3.5 text-base font-semibold text-[#1C4539] md:px-10 md:py-4"
      >
        Get Involved
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Programs ──────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-10 bg-[#dff8da] px-6 py-12 md:gap-12 md:px-20 md:py-20">
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-[13px] font-semibold tracking-[2px] text-[#668460]">OUR PROGRAMS</span>
      <h2 class="font-serif text-[28px] font-bold text-[#1C4539] md:text-[40px]">Driving Change Across Four Pillars</h2>
      <p class="max-w-[560px] text-base leading-relaxed text-[#4e6549]">
        Each program is designed to create lasting impact in communities that need it most.
      </p>
    </div>

    <div class="grid w-full grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="flex flex-col gap-4 rounded-xl border border-[#c7f3be] bg-white p-7 shadow-[0_4px_20px_rgba(28,69,57,0.05)]">
        <div class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]" style="background: linear-gradient(180deg, #c7f3be 0%, #dff8da 100%);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C4539" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1C4539]">Renewable Energy</h3>
        <p class="text-sm leading-[1.6] text-[#4e6549]">Deploying solar, wind, and biogas solutions to power communities sustainably and reduce carbon emissions.</p>
      </div>

      <div class="flex flex-col gap-4 rounded-xl border border-[#c7f3be] bg-white p-7 shadow-[0_4px_20px_rgba(28,69,57,0.05)]">
        <div class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]" style="background: linear-gradient(180deg, #c7f3be 0%, #dff8da 100%);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C4539" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1C4539]">Environmental Protection</h3>
        <p class="text-sm leading-[1.6] text-[#4e6549]">Preserving ecosystems, fighting pollution, and restoring biodiversity through grassroots conservation initiatives.</p>
      </div>

      <div class="flex flex-col gap-4 rounded-xl border border-[#c7f3be] bg-white p-7 shadow-[0_4px_20px_rgba(28,69,57,0.05)]">
        <div class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]" style="background: linear-gradient(180deg, #c7f3be 0%, #dff8da 100%);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C4539" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 22 16 8"/>
            <path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4z"/>
            <path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1C4539]">Agri-Processing</h3>
        <p class="text-sm leading-[1.6] text-[#4e6549]">Empowering farmers with modern processing techniques, storage solutions, and access to sustainable markets.</p>
      </div>

      <div class="flex flex-col gap-4 rounded-xl border border-[#c7f3be] bg-white p-7 shadow-[0_4px_20px_rgba(28,69,57,0.05)]">
        <div class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]" style="background: linear-gradient(180deg, #c7f3be 0%, #dff8da 100%);">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#1C4539" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1C4539]">Quality Education</h3>
        <p class="text-sm leading-[1.6] text-[#4e6549]">Building schools, training teachers, and creating curricula that integrate environmental literacy from day one.</p>
      </div>
    </div>
  </section>

  <!-- ── SDG Strip ─────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-6 bg-white px-6 py-10 md:px-20 md:py-12">
    <p class="text-[12px] font-semibold tracking-[2px] text-[#668460]">
      ALIGNED WITH THE UN SUSTAINABLE DEVELOPMENT GOALS
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#E5243B]">
        <span class="font-mono text-lg font-bold text-white">1</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#DDA63A]">
        <span class="font-mono text-lg font-bold text-white">2</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#C5192D]">
        <span class="font-mono text-lg font-bold text-white">4</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#FCC30B]">
        <span class="font-mono text-lg font-bold text-white">7</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#F99D26]">
        <span class="font-mono text-lg font-bold text-white">11</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#3F7E44]">
        <span class="font-mono text-lg font-bold text-white">13</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#56C02B]">
        <span class="font-mono text-lg font-bold text-white">15</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#19486A]">
        <span class="font-mono text-lg font-bold text-white">17</span>
      </div>
    </div>
  </section>

  <!-- ── Partner CTA ───────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-6 bg-[#1C4539] px-6 py-14 md:px-20 md:py-20">
    <h2 class="text-center font-serif text-[32px] font-bold text-white md:text-[48px]">Partner With Us</h2>
    <p class="max-w-[640px] text-center text-[16px] leading-[1.6] text-[#B9F0AE] md:text-[17px]">
      Together we can build a more sustainable future. Join our network of partners, donors, and changemakers making a real difference.
    </p>
    <div class="flex w-full flex-col items-center gap-4 sm:w-auto sm:flex-row">
      <a
        href="/partner"
        class="flex w-full items-center justify-center gap-2.5 rounded-full bg-[#B9F0AE] px-9 py-4 text-base font-semibold text-[#1C4539] sm:w-auto"
      >
        Become a Partner
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m11 17 2 2a1 1 0 1 0 3-3"/>
          <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/>
          <path d="m21 3 1 11h-1"/>
          <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/>
          <path d="M3 4h8"/>
        </svg>
      </a>
      <a
        href="/about"
        class="flex w-full items-center justify-center gap-2.5 rounded-full border border-white px-9 py-4 text-base font-medium text-white sm:w-auto"
      >
        Learn More
      </a>
    </div>
  </section>
</Layout>
