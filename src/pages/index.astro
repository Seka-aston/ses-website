---
import Layout from "../layouts/Layout.astro";

const heroImage =
  "https://images.unsplash.com/photo-1632486940292-821417562967?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjI5NDR8&ixlib=rb-4.1.0&q=80&w=1080";
---

<Layout title="Home">
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section
    class="relative flex h-[720px] items-center justify-center overflow-hidden px-20"
    style={`background-image: url('${heroImage}'); background-size: cover; background-position: center;`}
  >
    <div class="absolute inset-0 bg-[#1B3A28]/70"></div>

    <div class="relative z-10 flex flex-col items-center gap-7 text-center">
      <!-- Badge -->
      <div class="flex items-center gap-2 rounded-full bg-[#2D5E3A] px-5 py-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A8CCAF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          <line x1="2" y1="12" x2="22" y2="12"/>
        </svg>
        <span class="text-[13px] font-medium text-[#A8CCAF]">Environmental Sustainability NGO</span>
      </div>

      <!-- Headline -->
      <h1 class="max-w-[900px] font-serif text-[64px] font-bold leading-tight text-white">
        Sustainability, The Way to Go
      </h1>

      <!-- Subtitle -->
      <p class="max-w-[700px] text-[18px] leading-[1.6] text-[#7A9A80]">
        Protecting the next generation through impactful programs in renewable energy, environmental conservation, agricultural innovation, and quality education.
      </p>

      <!-- CTA -->
      <a
        href="/get-involved"
        class="flex items-center gap-2.5 rounded-full px-10 py-4 text-base font-semibold text-white"
        style="background: linear-gradient(180deg, #4A8C5E 0%, #2D5E3A 100%);"
      >
        Get Involved
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Programs ──────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-12 bg-[#F5F3EE] px-20 py-20">
    <!-- Header -->
    <div class="flex flex-col items-center gap-3 text-center">
      <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">OUR PROGRAMS</span>
      <h2 class="font-serif text-[40px] font-bold text-[#1B3A28]">Driving Change Across Four Pillars</h2>
      <p class="max-w-[560px] text-base leading-relaxed text-[#7A9A80]">
        Each program is designed to create lasting impact in communities that need it most.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid w-full grid-cols-4 gap-6">
      <!-- Renewable Energy -->
      <div class="flex flex-col gap-4 rounded-xl border border-[#E8EDE5] bg-white p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1B3A28]">Renewable Energy</h3>
        <p class="text-sm leading-[1.6] text-[#7A9A80]">
          Deploying solar, wind, and biogas solutions to power communities sustainably and reduce carbon emissions.
        </p>
      </div>

      <!-- Environmental Protection -->
      <div class="flex flex-col gap-4 rounded-xl border border-[#E8EDE5] bg-white p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1B3A28]">Environmental Protection</h3>
        <p class="text-sm leading-[1.6] text-[#7A9A80]">
          Preserving ecosystems, fighting pollution, and restoring biodiversity through grassroots conservation initiatives.
        </p>
      </div>

      <!-- Agri-Processing -->
      <div class="flex flex-col gap-4 rounded-xl border border-[#E8EDE5] bg-white p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 22 16 8"/>
            <path d="M3.47 12.53 5 11l1.53 1.53a3.5 3.5 0 0 1 0 4.94L5 19l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M7.47 8.53 9 7l1.53 1.53a3.5 3.5 0 0 1 0 4.94L9 15l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M11.47 4.53 13 3l1.53 1.53a3.5 3.5 0 0 1 0 4.94L13 11l-1.53-1.53a3.5 3.5 0 0 1 0-4.94z"/>
            <path d="M20 2h2v2a4 4 0 0 1-4 4h-2V6a4 4 0 0 1 4-4z"/>
            <path d="M11.47 17.47 13 19l-1.53 1.53a3.5 3.5 0 0 1-4.94 0L5 19l1.53-1.53a3.5 3.5 0 0 1 4.94 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1B3A28]">Agri-Processing</h3>
        <p class="text-sm leading-[1.6] text-[#7A9A80]">
          Empowering farmers with modern processing techniques, storage solutions, and access to sustainable markets.
        </p>
      </div>

      <!-- Quality Education -->
      <div class="flex flex-col gap-4 rounded-xl border border-[#E8EDE5] bg-white p-7 shadow-[0_4px_20px_rgba(27,58,40,0.05)]">
        <div
          class="flex h-[52px] w-[52px] items-center justify-center rounded-[14px]"
          style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
        >
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2D5E3A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c3 3 9 3 12 0v-5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-[#1B3A28]">Quality Education</h3>
        <p class="text-sm leading-[1.6] text-[#7A9A80]">
          Building schools, training teachers, and creating curricula that integrate environmental literacy from day one.
        </p>
      </div>
    </div>
  </section>

  <!-- ── SDG Strip ─────────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-6 bg-white px-20 py-12">
    <p class="text-[12px] font-semibold tracking-[2px] text-[#7A9A80]">
      ALIGNED WITH THE UN SUSTAINABLE DEVELOPMENT GOALS
    </p>
    <div class="flex items-center gap-3">
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#E5243B]">
        <span class="font-mono text-lg font-bold text-white">1</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#DDA63A]">
        <span class="font-mono text-lg font-bold text-white">2</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#C5192D]">
        <span class="font-mono text-lg font-bold text-white">4</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#FCC30B]">
        <span class="font-mono text-lg font-bold text-white">7</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#F99D26]">
        <span class="font-mono text-lg font-bold text-white">11</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#3F7E44]">
        <span class="font-mono text-lg font-bold text-white">13</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#56C02B]">
        <span class="font-mono text-lg font-bold text-white">15</span>
      </div>
      <div class="flex h-14 w-14 items-center justify-center rounded-lg bg-[#19486A]">
        <span class="font-mono text-lg font-bold text-white">17</span>
      </div>
    </div>
  </section>

  <!-- ── Partner CTA ───────────────────────────────────────────────────── -->
  <section class="flex flex-col items-center gap-6 bg-[#1B3A28] px-20 py-20">
    <h2 class="text-center font-serif text-[48px] font-bold text-white">Partner With Us</h2>
    <p class="max-w-[640px] text-center text-[17px] leading-[1.6] text-[#7A9A80]">
      Together we can build a more sustainable future. Join our network of partners, donors, and changemakers making a real difference.
    </p>
    <div class="flex items-center gap-4">
      <a
        href="/partner"
        class="flex items-center gap-2.5 rounded-full px-9 py-4 text-base font-semibold text-white"
        style="background: linear-gradient(180deg, #4A8C5E 0%, #2D5E3A 100%);"
      >
        Become a Partner
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m11 17 2 2a1 1 0 1 0 3-3"/>
          <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/>
          <path d="m21 3 1 11h-1"/>
          <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/>
          <path d="M3 4h8"/>
        </svg>
      </a>
      <a
        href="/about"
        class="flex items-center gap-2.5 rounded-full border border-[#7A9A80] px-9 py-4 text-base font-medium text-white"
      >
        Learn More
      </a>
    </div>
  </section>
</Layout>
