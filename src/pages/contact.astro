---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact" activePage="Contact">
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="flex h-[360px] flex-col items-center justify-center gap-4 bg-[#1B3A28] px-20">
    <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">CONTACT US</span>
    <h1 class="max-w-[800px] text-center font-serif text-[48px] font-bold leading-tight text-white">
      Let's Build a Greener Future Together
    </h1>
    <p class="max-w-[600px] text-center text-[17px] text-[#7A9A80]">
      Have a question, partnership idea, or want to learn more about our programs? Reach out.
    </p>
  </section>

  <!-- ── Contact Content ───────────────────────────────────────────────── -->
  <section class="flex gap-16 bg-[#F5F3EE] px-20 py-16">

    <!-- Left Column -->
    <div class="flex w-[440px] shrink-0 flex-col gap-9">

      <!-- Intro -->
      <div class="flex flex-col gap-4">
        <h2 class="font-serif text-[32px] font-bold text-[#1B3A28]">Work With Us</h2>
        <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
          Whether you're a government, NGO, corporation, or community leader, we'd love to explore how we can collaborate on impactful sustainability initiatives.
        </p>
      </div>

      <!-- Contact Details -->
      <div class="flex flex-col gap-5">
        <!-- Email -->
        <div class="flex items-center gap-3.5">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[12px]"
            style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[12px] font-medium text-[#7A9A80]">Email</span>
            <span class="text-[15px] font-medium text-[#1B3A28]">info@sustainenviro.org</span>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex items-center gap-3.5">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[12px]"
            style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.1 6.1l1.16-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[12px] font-medium text-[#7A9A80]">Phone</span>
            <span class="text-[15px] font-medium text-[#1B3A28]">+233 24 000 0000</span>
          </div>
        </div>

        <!-- Location -->
        <div class="flex items-center gap-3.5">
          <div
            class="flex h-11 w-11 shrink-0 items-center justify-center rounded-[12px]"
            style="background: linear-gradient(180deg, #A8CCAF 0%, #D6F0DB 100%);"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="flex flex-col gap-0.5">
            <span class="text-[12px] font-medium text-[#7A9A80]">Location</span>
            <span class="text-[15px] font-medium text-[#1B3A28]">Accra, Ghana</span>
          </div>
        </div>
      </div>

      <!-- Social Icons -->
      <div class="flex gap-3">
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.7 5.5 4.4 9 4.5-.9-4.3 4-6.6 7-3.8C20.1 5 21.6 3.7 22 4z"/>
          </svg>
        </div>
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </div>
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </div>
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <form class="flex flex-1 flex-col gap-6 rounded-[16px] border border-[#E8EDE5] bg-white p-10 shadow-[0_8px_32px_rgba(27,58,40,0.06)]">

      <!-- Row 1: Full Name + Organization -->
      <div class="flex gap-5">
        <div class="flex flex-1 flex-col gap-2">
          <label class="text-[13px] font-medium text-[#1B3A28]">Full Name</label>
          <input
            type="text"
            placeholder="John Doe"
            class="w-full rounded-lg border border-[#E8EDE5] bg-white px-4 py-3 text-[14px] text-[#1B3A28] outline-none placeholder:text-[#7A9A80]"
          />
        </div>
        <div class="flex flex-1 flex-col gap-2">
          <label class="text-[13px] font-medium text-[#1B3A28]">Organization</label>
          <input
            type="text"
            placeholder="Company or NGO name"
            class="w-full rounded-lg border border-[#E8EDE5] bg-white px-4 py-3 text-[14px] text-[#1B3A28] outline-none placeholder:text-[#7A9A80]"
          />
        </div>
      </div>

      <!-- Email Address -->
      <div class="flex flex-col gap-2">
        <label class="text-[13px] font-medium text-[#1B3A28]">Email Address</label>
        <input
          type="email"
          placeholder="you@example.com"
          class="w-full rounded-lg border border-[#E8EDE5] bg-white px-4 py-3 text-[14px] text-[#1B3A28] outline-none placeholder:text-[#7A9A80]"
        />
      </div>

      <!-- Program of Interest -->
      <div class="flex flex-col gap-2">
        <label class="text-[13px] font-medium text-[#1B3A28]">Program of Interest</label>
        <div class="relative">
          <select class="w-full appearance-none rounded-lg border border-[#E8EDE5] bg-white px-4 py-3 text-[14px] text-[#7A9A80] outline-none">
            <option value="" disabled selected>Select a program</option>
            <option value="renewable-energy">Renewable Energy</option>
            <option value="environmental-protection">Environmental Protection</option>
            <option value="agri-processing">Agri-Processing</option>
            <option value="quality-education">Quality Education</option>
          </select>
          <svg
            class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2"
            width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7A9A80" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          >
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </div>
      </div>

      <!-- Message -->
      <div class="flex flex-col gap-2">
        <label class="text-[13px] font-medium text-[#1B3A28]">Message</label>
        <textarea
          placeholder="Tell us how we can help..."
          rows="5"
          class="w-full resize-none rounded-lg border border-[#E8EDE5] bg-white px-4 py-3 text-[14px] text-[#1B3A28] outline-none placeholder:text-[#7A9A80]"
        ></textarea>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="flex w-full items-center justify-center gap-2 rounded-[10px] py-3.5 text-[15px] font-semibold text-white"
        style="background: linear-gradient(90deg, #4A8C5E 0%, #2D5E3A 100%);"
      >
        Send Message
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m22 2-7 20-4-9-9-4Z"/>
          <path d="M22 2 11 13"/>
        </svg>
      </button>
    </form>
  </section>
</Layout>
