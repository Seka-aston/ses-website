---
import Layout from "../layouts/Layout.astro";

const images = {
  p1: "https://images.unsplash.com/photo-1695995971618-fc66412d76c2?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjEzNzR8&ixlib=rb-4.1.0&q=80&w=1080",
  p2: "https://images.unsplash.com/photo-1767917920874-946c7d5fbf31?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjEzOTd8&ixlib=rb-4.1.0&q=80&w=1080",
  p3: "https://images.unsplash.com/photo-1572980220258-8fd9b2233ae9?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjE0MTB8&ixlib=rb-4.1.0&q=80&w=1080",
  p4: "https://images.unsplash.com/photo-1758685733940-b1c11d04f553?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4NDM0ODN8MHwxfHJhbmRvbXx8fHx8fHx8fDE3NzY5NjE0MjN8&ixlib=rb-4.1.0&q=80&w=1080",
};
---

<Layout title="Programs" activePage="Programs">
  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="flex h-[340px] flex-col items-center justify-center gap-4 bg-[#1B3A28] px-20 py-14">
    <span class="text-[13px] font-semibold tracking-[2px] text-[#4A8C5E]">OUR PROGRAMS</span>
    <h1 class="font-serif text-[52px] font-bold text-white">What We Do</h1>
    <p class="max-w-[580px] text-center text-[17px] text-[#7A9A80]">
      Four core programs addressing the most pressing sustainability challenges of our time.
    </p>
  </section>

  <!-- ── Program 1: Renewable Energy — image left, content right ──────── -->
  <section class="flex items-center gap-12 bg-[#F5F3EE] px-20 py-12">
    <!-- Image -->
    <div
      class="h-[400px] flex-1 rounded-xl shadow-[0_8px_28px_rgba(27,58,40,0.08)]"
      style={`background-image: url('${images.p1}'); background-size: cover; background-position: center;`}
    ></div>

    <!-- Content -->
    <div class="flex flex-1 flex-col gap-5">
      <span class="font-mono text-[14px] font-bold text-[#4A8C5E]">01</span>
      <h2 class="font-serif text-[36px] font-bold text-[#1B3A28]">Renewable Energy</h2>
      <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
        We deploy clean energy solutions that power communities while protecting the environment. From rural electrification to industrial-scale projects, our energy programs reduce dependence on fossil fuels and create lasting economic opportunity.
      </p>
      <div class="flex flex-col gap-2.5">
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Solar panel installation &amp; maintenance</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Biomass energy systems</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Community energy access programs</span>
        </div>
      </div>
      <a href="/contact" class="flex items-center gap-1.5">
        <span class="text-[14px] font-semibold text-[#4A8C5E]">Inquire</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Program 2: Environmental Protection — content left, image right ─ -->
  <section class="flex items-center gap-12 bg-white px-20 py-12">
    <!-- Content -->
    <div class="flex flex-1 flex-col gap-5">
      <span class="font-mono text-[14px] font-bold text-[#4A8C5E]">02</span>
      <h2 class="font-serif text-[36px] font-bold text-[#1B3A28]">Environmental Protection</h2>
      <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
        Our environmental protection programs combine rigorous science with community engagement to safeguard ecosystems. We conduct comprehensive assessments and implement practical solutions that balance development with conservation.
      </p>
      <div class="flex flex-col gap-2.5">
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Environmental Impact Assessment (EIA)</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Health Impact Assessment (HIA)</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Social Impact Assessment (SIA)</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Risk Assessment &amp; Management</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Waste Recycling &amp; Management</span>
        </div>
      </div>
      <a href="/contact" class="flex items-center gap-1.5">
        <span class="text-[14px] font-semibold text-[#4A8C5E]">Inquire</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Image -->
    <div
      class="h-[400px] flex-1 rounded-xl shadow-[0_8px_28px_rgba(27,58,40,0.08)]"
      style={`background-image: url('${images.p2}'); background-size: cover; background-position: center;`}
    ></div>
  </section>

  <!-- ── Program 3: Agri-Processing — image left, content right ──────── -->
  <section class="flex items-center gap-12 bg-[#F5F3EE] px-20 py-12">
    <!-- Image -->
    <div
      class="h-[400px] flex-1 rounded-xl shadow-[0_8px_28px_rgba(27,58,40,0.08)]"
      style={`background-image: url('${images.p3}'); background-size: cover; background-position: center;`}
    ></div>

    <!-- Content -->
    <div class="flex flex-1 flex-col gap-5">
      <span class="font-mono text-[14px] font-bold text-[#4A8C5E]">03</span>
      <h2 class="font-serif text-[36px] font-bold text-[#1B3A28]">Agri-Processing</h2>
      <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
        We help farming communities modernize their agricultural practices with sustainable processing techniques. Our programs connect smallholder farmers to better storage, processing, and market access — turning harvests into long-term livelihoods.
      </p>
      <div class="flex flex-col gap-2.5">
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Post-harvest processing &amp; storage</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Sustainable farming techniques training</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Market access &amp; value chain development</span>
        </div>
      </div>
      <a href="/contact" class="flex items-center gap-1.5">
        <span class="text-[14px] font-semibold text-[#4A8C5E]">Inquire</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ── Program 4: Quality Education — content left, image right ─────── -->
  <section class="flex items-center gap-12 bg-white px-20 py-12">
    <!-- Content -->
    <div class="flex flex-1 flex-col gap-5">
      <span class="font-mono text-[14px] font-bold text-[#4A8C5E]">04</span>
      <h2 class="font-serif text-[36px] font-bold text-[#1B3A28]">Quality Education</h2>
      <p class="text-[15px] leading-[1.7] text-[#7A9A80]">
        Education is the foundation of lasting change. We build schools, train teachers, and integrate environmental literacy into curricula — empowering the next generation with the knowledge and values to protect our planet.
      </p>
      <div class="flex flex-col gap-2.5">
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">School construction &amp; infrastructure</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Teacher training &amp; capacity building</span>
        </div>
        <div class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span class="text-[14px] font-medium text-[#1B3A28]">Environmental literacy curricula</span>
        </div>
      </div>
      <a href="/contact" class="flex items-center gap-1.5">
        <span class="text-[14px] font-semibold text-[#4A8C5E]">Inquire</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Image -->
    <div
      class="h-[400px] flex-1 rounded-xl shadow-[0_8px_28px_rgba(27,58,40,0.08)]"
      style={`background-image: url('${images.p4}'); background-size: cover; background-position: center;`}
    ></div>
  </section>
</Layout>
