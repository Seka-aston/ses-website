---
---

<footer class="bg-[#0F2518]">
  <!-- Main columns -->
  <div class="flex gap-16 px-20 py-14">
    <!-- Brand column -->
    <div class="flex w-[360px] shrink-0 flex-col gap-5">
      <div class="flex items-center gap-2.5">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4A8C5E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/>
          <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
        </svg>
        <span class="font-serif text-[22px] font-bold text-white">SustainEnviro</span>
      </div>
      <p class="w-[320px] text-sm leading-[1.7] text-white">
        Building a sustainable future through renewable energy, environmental protection, agricultural innovation, and quality education.
      </p>
      <div class="flex gap-3">
        <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.7 5.5 4.3 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
          </svg>
        </a>
        <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect width="4" height="12" x="2" y="9"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href="#" class="flex h-10 w-10 items-center justify-center rounded-full bg-[#2D5E3A]">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Programs column -->
    <div class="flex flex-1 flex-col gap-4">
      <h3 class="text-sm font-semibold text-white">Programs</h3>
      <ul class="flex flex-col gap-4">
        <li><a href="#" class="text-sm text-white">Renewable Energy</a></li>
        <li><a href="#" class="text-sm text-white">Environmental Protection</a></li>
        <li><a href="#" class="text-sm text-white">Agri-Processing</a></li>
        <li><a href="#" class="text-sm text-white">Quality Education</a></li>
      </ul>
    </div>

    <!-- Organization column -->
    <div class="flex flex-1 flex-col gap-4">
      <h3 class="text-sm font-semibold text-white">Organization</h3>
      <ul class="flex flex-col gap-4">
        <li><a href="#" class="text-sm text-white">About Us</a></li>
        <li><a href="#" class="text-sm text-white">Our Team</a></li>
        <li><a href="#" class="text-sm text-white">Impact Reports</a></li>
        <li><a href="#" class="text-sm text-white">Careers</a></li>
      </ul>
    </div>

    <!-- Get Involved column -->
    <div class="flex flex-1 flex-col gap-4">
      <h3 class="text-sm font-semibold text-white">Get Involved</h3>
      <ul class="flex flex-col gap-4">
        <li><a href="#" class="text-sm text-white">Partner With Us</a></li>
        <li><a href="#" class="text-sm text-white">Donate</a></li>
        <li><a href="#" class="text-sm text-white">Volunteer</a></li>
        <li><a href="#" class="text-sm text-white">Contact Us</a></li>
      </ul>
    </div>
  </div>

  <!-- Divider -->
  <div class="px-20">
    <div class="h-px bg-[#2D5E3A]"></div>
  </div>

  <!-- Copyright bar -->
  <div class="flex items-center justify-between px-20 py-5">
    <p class="text-[13px] text-white">© 2026 SustainEnviro Solutions. All rights reserved.</p>
    <div class="flex items-center gap-6">
      <a href="#" class="text-[13px] text-white">Privacy Policy</a>
      <a href="#" class="text-[13px] text-white">Terms of Service</a>
      <a href="#" class="text-[13px] text-white">Cookie Settings</a>
    </div>
  </div>
</footer>
